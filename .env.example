# ──────────────────────────────────────────────────────────────────────────
# Superset Auto-Remediation Pipeline — configuration
# Copy to `.env` and fill in. The stack talks to the REAL Devin + GitHub APIs.
# ──────────────────────────────────────────────────────────────────────────

# --- Devin API (https://docs.devin.ai/api-reference) ---
# Personal (apk_user_...) or Service (apk_...) API key.
DEVIN_API_KEY=dev-key
DEVIN_API_BASE=https://api.devin.ai

# --- GitHub ---
# Fine-grained or classic PAT with `repo` scope on your Superset fork.
GITHUB_TOKEN=ghp_replace_me
# The fork you cloned Superset into, as owner/repo.
GITHUB_REPO=org/repo

# --- Pipeline behavior ---
# How often (seconds) the vulnerability scanner runs. 0 disables it.
SCANNER_INTERVAL_SECONDS=3600
# Requirements files in the fork that the OSV scanner inspects (comma-separated).
SCANNER_REQUIREMENTS_PATHS=requirements/base.txt
# How often (seconds) the poller checks in-flight Devin sessions.
POLL_INTERVAL_SECONDS=30
# Safety cap on Devin compute per session (ACUs). Keeps demo cost bounded.
MAX_ACU_LIMIT=10
# If true, the scanner detects + files issues but does NOT auto-start Devin
# (human-in-the-loop: a maintainer dispatches via POST /remediate/<n>). If
# false, scanner findings flow straight to Devin.
SCANNER_REQUIRES_APPROVAL=false

# --- Storage ---
DATABASE_PATH=./data/pipeline.db
